<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Windows 10 Simulator</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Segoe+UI:wght@300;400;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; user-select: none; }

  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow: hidden;
    height: 100vh;
    width: 100vw;
  }

  /* ===== LOCK SCREEN ===== */
  #lockScreen {
    position: fixed; inset: 0; z-index: 10000;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080"><defs><linearGradient id="g" x1="0%25" y1="0%25" x2="100%25" y2="100%25"><stop offset="0%25" stop-color="%230078D4"/><stop offset="50%25" stop-color="%23005A9E"/><stop offset="100%25" stop-color="%23003F72"/></linearGradient></defs><rect fill="url(%23g)" width="1920" height="1080"/></svg>') center/cover;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: white; cursor: pointer;
    transition: opacity 0.5s, transform 0.5s;
  }
  #lockScreen.hide { opacity: 0; transform: translateY(-100%); pointer-events: none; }
  #lockTime { font-size: 96px; font-weight: 300; }
  #lockDate { font-size: 24px; font-weight: 300; margin-top: 5px; }
  #lockHint { position: absolute; bottom: 60px; font-size: 16px; opacity: 0.7; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{ opacity:0.4; } 50%{ opacity:1; } }

  /* ===== LOGIN SCREEN ===== */
  #loginScreen {
    position: fixed; inset: 0; z-index: 9999;
    background: linear-gradient(135deg, #0078D4, #005A9E);
    display: none; flex-direction: column; align-items: center; justify-content: center;
    color: white;
    transition: opacity 0.5s;
  }
  #loginScreen.show { display: flex; }
  #loginScreen.hide { opacity: 0; pointer-events: none; }
  .avatar {
    width: 120px; height: 120px; border-radius: 50%;
    background: #444; display: flex; align-items: center; justify-content: center;
    font-size: 48px; margin-bottom: 15px;
  }
  #loginScreen .username { font-size: 22px; margin-bottom: 20px; }
  #loginScreen input {
    padding: 10px 15px; width: 280px; border: 2px solid rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.15); color: white; font-size: 15px;
    border-radius: 3px; outline: none;
  }
  #loginScreen input::placeholder { color: rgba(255,255,255,0.6); }
  #loginBtn {
    margin-top: 10px; padding: 8px 30px; background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.4); color: white; cursor: pointer;
    border-radius: 3px; font-size: 14px;
  }
  #loginBtn:hover { background: rgba(255,255,255,0.3); }

  /* ===== DESKTOP ===== */
  #desktop {
    width: 100vw; height: 100vh;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080"><defs><radialGradient id="g" cx="50%25" cy="40%25" r="70%25"><stop offset="0%25" stop-color="%230078D4"/><stop offset="100%25" stop-color="%23001a33"/></radialGradient></defs><rect fill="url(%23g)" width="1920" height="1080"/></svg>') center/cover;
    position: relative;
    display: none;
  }
  #desktop.show { display: block; }

  /* Desktop Icons */
  .desktop-icons {
    padding: 20px;
    display: flex; flex-direction: column; flex-wrap: wrap;
    gap: 10px; height: calc(100vh - 48px);
    align-content: flex-start;
  }
  .desktop-icon {
    width: 80px; padding: 8px 5px; text-align: center;
    border-radius: 4px; cursor: pointer; transition: background 0.15s;
  }
  .desktop-icon:hover { background: rgba(255,255,255,0.15); }
  .desktop-icon.selected { background: rgba(255,255,255,0.25); border: 1px solid rgba(255,255,255,0.4); }
  .desktop-icon .icon { font-size: 36px; display: block; margin-bottom: 4px; }
  .desktop-icon .label { font-size: 11px; color: white; text-shadow: 1px 1px 3px rgba(0,0,0,0.8); word-wrap: break-word; }

  /* ===== TASKBAR ===== */
  #taskbar {
    position: fixed; bottom: 0; left: 0; right: 0;
    height: 48px; background: rgba(23,23,23,0.95);
    display: flex; align-items: center; z-index: 5000;
    backdrop-filter: blur(20px);
  }
  #startBtn {
    width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.15s;
  }
  #startBtn:hover { background: rgba(255,255,255,0.1); }
  #startBtn svg { width: 18px; height: 18px; fill: white; }

  #searchBar {
    height: 34px; width: 280px; margin-left: 4px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 3px; display: flex; align-items: center; padding: 0 10px;
    color: rgba(255,255,255,0.5); font-size: 13px; cursor: text;
  }
  #searchBar span { margin-left: 8px; }

  .taskbar-icons {
    display: flex; margin-left: 8px; height: 100%;
  }
  .taskbar-item {
    height: 48px; min-width: 48px; padding: 0 12px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; color: white; font-size: 13px;
    transition: background 0.15s;
  }
  .taskbar-item:hover { background: rgba(255,255,255,0.1); }
  .taskbar-item.active::after {
    content: ''; position: absolute; bottom: 0; left: 20%; right: 20%;
    height: 3px; background: #0078D4; border-radius: 2px 2px 0 0;
  }
  .taskbar-item .t-icon { font-size: 20px; margin-right: 6px; }

  .system-tray {
    margin-left: auto; display: flex; align-items: center; height: 100%;
    color: white; font-size: 12px;
  }
  .tray-icon {
    height: 48px; padding: 0 8px; display: flex; align-items: center;
    cursor: pointer; transition: background 0.15s; font-size: 16px;
  }
  .tray-icon:hover { background: rgba(255,255,255,0.1); }
  #trayClock { padding: 0 12px; text-align: right; line-height: 1.4; font-size: 12px; cursor: pointer; }

  /* ===== START MENU ===== */
  #startMenu {
    position: fixed; bottom: 48px; left: 0;
    width: 600px; height: 500px;
    background: rgba(23,23,23,0.97);
    backdrop-filter: blur(30px);
    z-index: 6000; display: none;
    animation: slideUp 0.2s ease-out;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  #startMenu.show { display: flex; }
  @keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  .start-left {
    width: 50px; background: rgba(255,255,255,0.03);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 8px 0;
  }
  .start-left-icon {
    width: 50px; height: 44px; display: flex; align-items: center; justify-content: center;
    color: white; font-size: 18px; cursor: pointer; transition: background 0.15s;
  }
  .start-left-icon:hover { background: rgba(255,255,255,0.1); }

  .start-apps {
    flex: 1; padding: 10px 15px; overflow-y: auto; color: white;
  }
  .start-apps::-webkit-scrollbar { width: 4px; }
  .start-apps::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 2px; }
  .start-apps h3 { font-size: 13px; font-weight: 600; padding: 8px 0 4px; color: rgba(255,255,255,0.5); }
  .start-app-item {
    padding: 8px 10px; display: flex; align-items: center; gap: 12px;
    cursor: pointer; border-radius: 3px; transition: background 0.15s; font-size: 14px;
  }
  .start-app-item:hover { background: rgba(255,255,255,0.1); }
  .start-app-item .sa-icon { font-size: 22px; width: 30px; text-align: center; }

  .start-tiles {
    width: 280px; padding: 10px; display: grid;
    grid-template-columns: 1fr 1fr; gap: 4px;
    align-content: start;
  }
  .tile {
    height: 80px; border-radius: 3px; display: flex;
    flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; color: white; font-size: 12px;
    transition: transform 0.15s, filter 0.15s;
  }
  .tile:hover { transform: scale(1.03); filter: brightness(1.15); }
  .tile .tile-icon { font-size: 28px; margin-bottom: 6px; }
  .tile.wide { grid-column: span 2; }

  /* ===== WINDOWS ===== */
  .window {
    position: absolute;
    min-width: 400px; min-height: 300px;
    background: #1e1e1e;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px 6px 0 0;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
    display: flex; flex-direction: column;
    animation: windowOpen 0.25s ease-out;
  }
  @keyframes windowOpen { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .window.closing { animation: windowClose 0.2s ease-in forwards; }
  @keyframes windowClose { to { transform: scale(0.9); opacity: 0; } }
  .window.maximized { top: 0 !important; left: 0 !important; width: 100vw !important; height: calc(100vh - 48px) !important; border-radius: 0; }

  .window-header {
    height: 36px; background: #2d2d2d;
    display: flex; align-items: center;
    cursor: move; flex-shrink: 0;
  }
  .window-header .wh-icon { margin-left: 10px; font-size: 14px; }
  .window-header .wh-title { margin-left: 8px; color: white; font-size: 12px; flex: 1; }
  .window-controls { display: flex; height: 100%; }
  .window-controls button {
    width: 46px; height: 100%; border: none; background: transparent;
    color: rgba(255,255,255,0.7); font-size: 14px; cursor: pointer;
    transition: background 0.1s;
  }
  .window-controls button:hover { background: rgba(255,255,255,0.1); }
  .window-controls .close-btn:hover { background: #e81123; color: white; }

  .window-body {
    flex: 1; overflow: auto; color: white; font-size: 14px;
  }

  /* ===== FILE EXPLORER ===== */
  .explorer-toolbar {
    display: flex; align-items: center; padding: 6px 12px;
    background: #2d2d2d; border-bottom: 1px solid rgba(255,255,255,0.05);
    gap: 8px;
  }
  .explorer-toolbar button {
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    color: white; padding: 4px 10px; border-radius: 3px; cursor: pointer; font-size: 12px;
  }
  .explorer-toolbar button:hover { background: rgba(255,255,255,0.15); }
  .explorer-path {
    flex: 1; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8); padding: 4px 10px; border-radius: 3px; font-size: 12px;
  }
  .explorer-sidebar {
    width: 200px; background: rgba(255,255,255,0.02);
    border-right: 1px solid rgba(255,255,255,0.05);
    padding: 10px 0;
  }
  .explorer-sidebar-item {
    padding: 5px 15px; cursor: pointer; font-size: 13px;
    display: flex; align-items: center; gap: 8px;
    transition: background 0.15s;
  }
  .explorer-sidebar-item:hover { background: rgba(255,255,255,0.08); }
  .explorer-sidebar-item.active { background: rgba(255,255,255,0.1); }
  .explorer-content { flex: 1; padding: 15px; display: flex; flex-wrap: wrap; gap: 10px; align-content: flex-start; }
  .explorer-item {
    width: 80px; text-align: center; padding: 8px 5px;
    border-radius: 4px; cursor: pointer; transition: background 0.15s;
  }
  .explorer-item:hover { background: rgba(255,255,255,0.1); }
  .explorer-item .ei-icon { font-size: 36px; }
  .explorer-item .ei-name { font-size: 11px; margin-top: 4px; word-wrap: break-word; }

  /* ===== NOTEPAD ===== */
  .notepad-menu {
    display: flex; padding: 2px 5px; background: #2d2d2d;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .notepad-menu span {
    padding: 3px 10px; cursor: pointer; font-size: 12px; color: rgba(255,255,255,0.8);
    border-radius: 3px;
  }
  .notepad-menu span:hover { background: rgba(255,255,255,0.1); }
  .notepad-textarea {
    width: 100%; flex: 1; background: #1e1e1e; color: white;
    border: none; padding: 10px; font-family: 'Consolas', monospace;
    font-size: 14px; resize: none; outline: none;
  }

  /* ===== CALCULATOR ===== */
  .calc-display {
    padding: 20px 15px 10px; text-align: right;
    font-size: 40px; font-weight: 300; color: white;
    background: #1e1e1e; min-height: 80px;
    overflow: hidden;
  }
  .calc-buttons {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 2px; padding: 4px;
  }
  .calc-btn {
    padding: 18px; border: none; font-size: 18px;
    cursor: pointer; transition: background 0.1s;
    background: #3b3b3b; color: white;
  }
  .calc-btn:hover { background: #4a4a4a; }
  .calc-btn.operator { background: #323232; }
  .calc-btn.operator:hover { background: #444; }
  .calc-btn.equals { background: #0078D4; }
  .calc-btn.equals:hover { background: #1a8ae6; }
  .calc-btn.clear { background: #a33; }
  .calc-btn.clear:hover { background: #c44; }

  /* ===== SETTINGS ===== */
  .settings-container { display: flex; height: 100%; }
  .settings-sidebar {
    width: 220px; background: rgba(255,255,255,0.03);
    border-right: 1px solid rgba(255,255,255,0.05);
    padding: 15px 0;
  }
  .settings-item {
    padding: 10px 20px; cursor: pointer; font-size: 14px;
    display: flex; align-items: center; gap: 12px;
    transition: background 0.15s;
  }
  .settings-item:hover { background: rgba(255,255,255,0.08); }
  .settings-item.active { background: rgba(0,120,212,0.2); border-left: 3px solid #0078D4; }
  .settings-content { flex: 1; padding: 25px; }
  .settings-content h2 { font-size: 28px; font-weight: 300; margin-bottom: 20px; }
  .settings-option {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .toggle-switch {
    width: 44px; height: 22px; background: #555; border-radius: 11px;
    cursor: pointer; position: relative; transition: background 0.3s;
  }
  .toggle-switch.on { background: #0078D4; }
  .toggle-switch::after {
    content: ''; position: absolute; width: 16px; height: 16px;
    background: white; border-radius: 50%; top: 3px; left: 3px;
    transition: left 0.3s;
  }
  .toggle-switch.on::after { left: 25px; }

  /* ===== BROWSER ===== */
  .browser-toolbar {
    display: flex; align-items: center; padding: 6px 10px;
    background: #2d2d2d; gap: 6px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .browser-toolbar button {
    background: none; border: none; color: rgba(255,255,255,0.6);
    font-size: 16px; cursor: pointer; padding: 4px 8px; border-radius: 3px;
  }
  .browser-toolbar button:hover { background: rgba(255,255,255,0.1); }
  .browser-url {
    flex: 1; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
    color: white; padding: 5px 12px; border-radius: 20px; font-size: 13px; outline: none;
  }
  .browser-content {
    flex: 1; background: #fff; color: #333; padding: 40px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .browser-content h1 { font-size: 24px; color: #202124; margin-bottom: 25px; }
  .browser-search-box {
    width: 500px; max-width: 90%; padding: 12px 20px;
    border: 1px solid #dfe1e5; border-radius: 24px;
    font-size: 16px; outline: none;
  }
  .browser-search-box:focus { box-shadow: 0 1px 6px rgba(32,33,36,0.28); }

  /* ===== TERMINAL ===== */
  .terminal-body {
    background: #0c0c0c; color: #ccc; padding: 10px;
    font-family: 'Consolas', monospace; font-size: 14px;
    flex: 1; overflow-y: auto;
  }
  .terminal-body .line { margin-bottom: 2px; }
  .terminal-body .prompt { color: #5bc0de; }
  .terminal-input-line { display: flex; }
  .terminal-input {
    background: transparent; border: none; color: #ccc;
    font-family: 'Consolas', monospace; font-size: 14px;
    outline: none; flex: 1;
  }

  /* ===== CONTEXT MENU ===== */
  #contextMenu {
    position: fixed; min-width: 220px;
    background: rgba(43,43,43,0.97); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px; padding: 4px 0;
    z-index: 8000; display: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    animation: fadeIn 0.12s;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .ctx-item {
    padding: 8px 20px; color: white; font-size: 13px;
    cursor: pointer; display: flex; justify-content: space-between;
    transition: background 0.1s;
  }
  .ctx-item:hover { background: rgba(255,255,255,0.1); }
  .ctx-sep { height: 1px; background: rgba(255,255,255,0.08); margin: 4px 0; }

  /* ===== NOTIFICATION ===== */
  .notification {
    position: fixed; top: -80px; right: 20px;
    background: rgba(43,43,43,0.97); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px; padding: 15px 20px; color: white;
    z-index: 9000; min-width: 300px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    transition: top 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .notification.show { top: 20px; }
  .notification .n-title { font-weight: 600; font-size: 13px; }
  .notification .n-text { font-size: 12px; opacity: 0.7; margin-top: 4px; }

  /* ===== ACTION CENTER ===== */
  #actionCenter {
    position: fixed; top: 0; right: -380px; bottom: 48px;
    width: 380px; background: rgba(23,23,23,0.97);
    backdrop-filter: blur(30px); z-index: 7000;
    transition: right 0.3s ease; padding: 15px;
    border-left: 1px solid rgba(255,255,255,0.05);
    color: white; overflow-y: auto;
  }
  #actionCenter.show { right: 0; }
  .ac-header { font-size: 14px; font-weight: 600; margin-bottom: 15px; display: flex; justify-content: space-between; }
  .quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px; margin-top: 15px; }
  .qa-btn {
    height: 60px; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    background: rgba(255,255,255,0.05); border-radius: 3px;
    cursor: pointer; font-size: 10px; gap: 4px;
    transition: background 0.15s;
  }
  .qa-btn:hover { background: rgba(255,255,255,0.12); }
  .qa-btn.active { background: #0078D4; }
  .qa-btn .qa-icon { font-size: 18px; }
  .slider-container { margin-top: 20px; }
  .slider-container label { font-size: 12px; opacity: 0.7; display: flex; align-items: center; gap: 8px; }
  .slider-container input[type="range"] {
    width: 100%; margin-top: 8px; accent-color: #0078D4;
  }
</style>
</head>
<body>

<!-- LOCK SCREEN -->
<div id="lockScreen">
  <div id="lockTime">12:00</div>
  <div id="lockDate">piątek, 6 marca</div>
  <div id="lockHint">Kliknij aby odblokować</div>
</div>

<!-- LOGIN SCREEN -->
<div id="loginScreen">
  <div class="avatar">👤</div>
  <div class="username">Użytkownik</div>
  <input type="password" id="loginPass" placeholder="Hasło (wciśnij Enter)" autocomplete="off">
  <button id="loginBtn">→ Zaloguj</button>
</div>

<!-- DESKTOP -->
<div id="desktop">
  <div class="desktop-icons" id="desktopIcons"></div>
</div>

<!-- TASKBAR -->
<div id="taskbar" style="display:none;">
  <div id="startBtn">
    <svg viewBox="0 0 88 88"><path d="M0 0h42v42H0zM46 0h42v42H46zM0 46h42v42H0zM46 46h42v42H46z"/></svg>
  </div>
  <div id="searchBar">
    <span>🔍</span>
    <span>Wyszukaj w Windows</span>
  </div>
  <div class="taskbar-icons" id="taskbarItems"></div>
  <div class="system-tray">
    <div class="tray-icon" id="trayWifi" title="Wi-Fi">📶</div>
    <div class="tray-icon" id="trayVolume" title="Głośność">🔊</div>
    <div class="tray-icon" id="trayBattery" title="Bateria">🔋</div>
    <div id="trayClock">
      <div id="trayTime"></div>
      <div id="trayDate"></div>
    </div>
    <div class="tray-icon" id="trayNotif" title="Centrum akcji">💬</div>
  </div>
</div>

<!-- START MENU -->
<div id="startMenu">
  <div class="start-left">
    <div class="start-left-icon" title="Użytkownik">👤</div>
    <div class="start-left-icon" title="Ustawienia" onclick="openApp('settings')">⚙️</div>
    <div class="start-left-icon" title="Zasilanie" onclick="showShutdownMenu()">⏻</div>
  </div>
  <div class="start-apps" id="startAppsList"></div>
  <div class="start-tiles" id="startTiles"></div>
</div>

<!-- CONTEXT MENU -->
<div id="contextMenu"></div>

<!-- ACTION CENTER -->
<div id="actionCenter">
  <div class="ac-header">
    <span>Centrum akcji</span>
    <span style="cursor:pointer;opacity:0.5;" onclick="toggleActionCenter()">✕</span>
  </div>
  <div style="padding:10px;background:rgba(255,255,255,0.03);border-radius:4px;margin-bottom:10px;">
    <div style="font-size:13px;">📧 Poczta</div>
    <div style="font-size:12px;opacity:0.6;margin-top:4px;">Masz 3 nowe wiadomości</div>
  </div>
  <div style="padding:10px;background:rgba(255,255,255,0.03);border-radius:4px;">
    <div style="font-size:13px;">🛡️ Zabezpieczenia Windows</div>
    <div style="font-size:12px;opacity:0.6;margin-top:4px;">Twoje urządzenie jest chronione</div>
  </div>
