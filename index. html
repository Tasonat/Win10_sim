// SHUTDOWN MENU
function showShutdownMenu() {
  const menu = document.getElementById('contextMenu');
  menu.innerHTML = `
    <div class="ctx-item" onclick="doShutdown('sleep')">😴 Uśpij</div>
    <div class="ctx-item" onclick="doShutdown('shutdown')">⏻ Zamknij</div>
    <div class="ctx-item" onclick="doShutdown('restart')">🔄 Uruchom ponownie</div>
  `;
  menu.style.left = '10px';
  menu.style.bottom = '90px';
  menu.style.top = 'auto';
  menu.style.display = 'block';
}

function doShutdown(type) {
  document.getElementById('contextMenu').style.display = 'none';
  if (startMenuOpen) toggleStartMenu();

  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:black;z-index:20000;display:flex;flex-direction:column;align-items:center;justify-content:center;color:white;animation:fadeIn 1s;';

  if (type === 'shutdown') {
    overlay.innerHTML = '<div style="font-size:20px;">Zamykanie systemu...</div><div style="margin-top:20px;width:40px;height:40px;border:3px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 1s linear infinite;"></div>';
  } else if (type === 'restart') {
    overlay.innerHTML = '<div style="font-size:20px;">Ponowne uruchamianie...</div><div style="margin-top:20px;width:40px;height:40px;border:3px solid rgba(255,255,255,0.3);border-top-color:white;border-radius:50%;animation:spin 1s linear infinite;"></div>';
  } else {
    overlay.innerHTML = '';
  }

  const style = document.createElement('style');
  style.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
  overlay.appendChild(style);
  document.body.appendChild(overlay);

  if (type === 'restart') {
    setTimeout(() => {
      overlay.remove();
      // Reset to lock screen
      document.getElementById('desktop').classList.remove('show');
      document.getElementById('taskbar').style.display = 'none';
      windows.forEach(w => w.element.remove());
      windows = [];
      document.getElementById('lockScreen').classList.remove('hide');
      document.getElementById('loginScreen').classList.remove('show', 'hide');
      document.getElementById('loginScreen').style.display = '';
    }, 3000);
  }
}

