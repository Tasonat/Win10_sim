// ===== WINDOW MANAGEMENT =====
function createWindow(id, title, icon, width, height, bodyHTML) {
  const existing = windows.find(w => w.id === id);
  if (existing) {
    focusWindow(id);
    return;
  }

  const win = document.createElement('div');
  win.className = 'window';
  win.id = `win-${id}`;
  win.style.width = width + 'px';
  win.style.height = height + 'px';
  win.style.left = (100 + windows.length * 30) + 'px';
  win.style.top = (60 + windows.length * 30) + 'px';
  win.style.zIndex = ++windowZIndex;

  win.innerHTML = `
    <div class="window-header">
      <span class="wh-icon">${icon}</span>
      <span class="wh-title">${title}</span>
      <div class="window-controls">
        <button onclick="minimizeWindow('${id}')">─</button>
        <button onclick="maximizeWindow('${id}')">☐</button>
        <button class="close-btn" onclick="closeWindow('${id}')">✕</button>
      </div>
    </div>
    <div class="window-body">${bodyHTML}</div>
  `;

  win.addEventListener('mousedown', () => focusWindow(id));

  // Dragging
  const header = win.querySelector('.window-header');
  header.addEventListener('mousedown', (e) => {
    if (e.target.tagName === 'BUTTON') return;
    if (win.classList.contains('maximized')) return;
    dragState = { win, startX: e.clientX, startY: e.clientY, origLeft: parseInt(win.style.left), origTop: parseInt(win.style.top) };
  });

  document.getElementById('desktop').appendChild(win);
  windows.push({ id, title, icon, element: win, minimized: false });
  updateTaskbar();
  focusWindow(id);
}

document.addEventListener('mousemove', (e) => {
  if (!dragState) return;
  dragState.win.style.left = (dragState.origLeft + e.clientX - dragState.startX) + 'px';
  dragState.win.style.top = (dragState.origTop + e.clientY - dragState.startY) + 'px';
});
document.addEventListener('mouseup', () => { dragState = null; });

function focusWindow(id) {
  const w = windows.find(w => w.id === id);
  if (!w) return;
  w.element.style.zIndex = ++windowZIndex;
  if (w.minimized) {
    w.element.style.display = 'flex';
    w.minimized = false;
  }
  activeWindowId = id;
  updateTaskbar();
}

function minimizeWindow(id) {
  const w = windows.find(w => w.id === id);
  if (!w) return;
  w.element.style.display = 'none';
  w.minimized = true;
  activeWindowId = null;
  updateTaskbar();
}

function maximizeWindow(id) {
  const w = windows.find(w => w.id === id);
  if (!w) return;
  w.element.classList.toggle('maximized');
}

function closeWindow(id) {
  const w = windows.find(w => w.id === id);
  if (!w) return;
  w.element.classList.add('closing');
  setTimeout(() => {
    w.element.remove();
    windows = windows.filter(w => w.id !== id);
    if (activeWindowId === id) activeWindowId = null;
    updateTaskbar();
  }, 200);
}

function updateTaskbar() {
  const container = document.getElementById('taskbarItems');
  container.innerHTML = '';
  windows.forEach(w => {
    const el = document.createElement('div');
    el.className = `taskbar-item ${activeWindowId === w.id ? 'active' : ''}`;
    el.innerHTML = `<span class="t-icon">${w.icon}</span><span>${w.title}</span>`;
    el.addEventListener('click', () => {
      if (activeWindowId === w.id && !w.minimized) {
        minimizeWindow(w.id);
      } else {
        focusWindow(w.id);
      }
    });
    container.appendChild(el);
  });
}

