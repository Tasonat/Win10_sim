// CALCULATOR
let calcDisplay = '0';
let calcPrev = '';
let calcOp = '';
let calcReset = false;

function openCalculator() {
  const btns = [
    ['C','clear'],['⌫','operator'],['%','operator'],['÷','operator'],
    ['7',''],['8',''],['9',''],['×','operator'],
    ['4',''],['5',''],['6',''],['−','operator'],
    ['1',''],['2',''],['3',''],['＋','operator'],
    ['±',''],['0',''],['.',''],[' = ','equals'],
  ];
  const btnHtml = btns.map(b => `<button class="calc-btn ${b[1]}" onclick="calcPress('${b[0]}')">${b[0]}</button>`).join('');

  createWindow('calculator', 'Kalkulator', '🧮', 320, 470, `
    <div class="calc-display" id="calcDisplay">0</div>
    <div class="calc-buttons">${btnHtml}</div>
  `);
  calcDisplay = '0'; calcPrev = ''; calcOp = ''; calcReset = false;
}

function calcPress(val) {
  const display = document.getElementById('calcDisplay');
  if (!display) return;

  if (val === 'C') {
    calcDisplay = '0'; calcPrev = ''; calcOp = ''; calcReset = false;
  } else if (val === '⌫') {
    calcDisplay = calcDisplay.length > 1 ? calcDisplay.slice(0, -1) : '0';
  } else if (['+','−','×','÷','＋'].includes(val)) {
    calcPrev = calcDisplay;
    calcOp = val;
    calcReset = true;
  } else if (val.includes('=')) {
    const a = parseFloat(calcPrev);
    const b = parseFloat(calcDisplay);
    let result = 0;
    switch (calcOp) {
      case '＋': result = a + b; break;
      case '−': result = a - b; break;
      case '×': result = a * b; break;
      case '÷': result = b !== 0 ? a / b : 'Błąd'; break;
      case '%': result = a % b; break;
      default: result = b;
    }
    calcDisplay = result.toString();
    calcOp = '';
    calcReset = true;
  } else if (val === '±') {
    calcDisplay = (parseFloat(calcDisplay) * -1).toString();
  } else {
    if (calcDisplay === '0' || calcReset) { calcDisplay = val; calcReset = false; }
    else calcDisplay += val;
  }
  display.textContent = calcDisplay;
}

