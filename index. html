function handleTerminal(e) {
  if (e.key !== 'Enter') return;
  const input = e.target;
  const cmd = input.value.trim();
  const body = document.getElementById('terminalBody');
  if (!body) return;

  // Remove input line
  const inputLine = input.parentElement;
  inputLine.innerHTML = `<span class="prompt">PS C:\\Users\\Użytkownik&gt; </span>${cmd}`;

  let output = '';
  const lc = cmd.toLowerCase();
  if (lc === 'dir' || lc === 'ls') {
    output = `
      <div class="line">    Katalog: C:\\Users\\Użytkownik</div>
      <div class="line">&nbsp;</div>
      <div class="line">d----    06.03.2026  12:00    Dokumenty</div>
      <div class="line">d----    06.03.2026  12:00    Pobrane</div>
      <div class="line">d----    06.03.2026  12:00    Pulpit</div>
      <div class="line">d----    06.03.2026  12:00    Obrazy</div>
      <div class="line">d----    06.03.2026  12:00    Muzyka</div>
    `;
  } else if (lc === 'cls' || lc === 'clear') {
    body.innerHTML = '';
  } else if (lc === 'date') {
    output = `<div class="line">${new Date().toLocaleString('pl-PL')}</div>`;
  } else if (lc === 'whoami') {
    output = `<div class="line">DESKTOP-WIN10\\Użytkownik</div>`;
  } else if (lc === 'hostname') {
    output = `<div class="line">DESKTOP-WIN10</div>`;
  } else if (lc === 'ipconfig') {
    output = `
      <div class="line">Konfiguracja IP systemu Windows</div>
      <div class="line">&nbsp;</div>
      <div class="line">Karta Ethernet:</div>
      <div class="line">   Adres IPv4. . . . . : 192.168.1.42</div>
      <div class="line">   Maska podsieci . . : 255.255.255.0</div>
      <div class="line">   Brama domyślna . . : 192.168.1.1</div>
    `;
  } else if (lc === 'systeminfo') {
    output = `
      <div class="line">Nazwa hosta:          DESKTOP-WIN10</div>
      <div class="line">Nazwa systemu:        Microsoft Windows 10 Pro</div>
      <div class="line">Wersja systemu:       10.0.19045</div>
      <div class="line">Procesor:             Intel Core i7-12700K</div>
      <div class="line">Pamięć RAM:           16384 MB</div>
    `;
  } else if (lc.startsWith('echo ')) {
    output = `<div class="line">${cmd.slice(5)}</div>`;
  } else if (lc === 'help') {
    output = `
      <div class="line">Dostępne komendy: dir, ls, cls, clear, date, whoami,</div>
      <div class="line">hostname, ipconfig, systeminfo, echo, help, exit</div>
    `;
  } else if (lc === 'exit') {
    closeWindow('terminal'); return;
  } else if (cmd !== '') {
    output = `<div class="line" style="color:#e74c3c;">'${cmd}' nie jest rozpoznawane jako polecenie wewnętrzne</div>`;
  }

  if (output) body.insertAdjacentHTML('beforeend', output);

  // New input line
  const newLine = document.createElement('div');
  newLine.className = 'terminal-input-line';
  newLine.innerHTML = `<span class="prompt">PS C:\\Users\\Użytkownik&gt; </span><input class="terminal-input" id="terminalInput" onkeydown="handleTerminal(event)">`;
  body.appendChild(newLine);
  const newInput = newLine.querySelector('input');
  newInput.focus();
  body.scrollTop = body.scrollHeight;
}

